[Unit]
Description=Finance Suite FastAPI Service
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/finance-suite-web
Environment="PATH=/home/ubuntu/finance-suite-web/venv/bin"
ExecStart=/home/ubuntu/finance-suite-web/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 4
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

